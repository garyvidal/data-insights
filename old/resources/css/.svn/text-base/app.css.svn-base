html, body {
		background:	#666;
		width:		100%;
		height:		100%;					
		padding:	0;
		margin:		0;
		font-size:10px;
		overflow:	auto; /* when page gets too small */
	}
.link {cursor: pointer; cursor: hand 	}	
#frame {
  margin:.4em;
  border:2px solid #903;
  width:90%;
  height:90%;
  display:block;}
  
#header {
  backgroundx: url("../images/header.png") no-repeat scroll left top transparent;
    background: #000;
    color: #ECEFDA;
    font-size: 18px;
    height: 65px;
    margin: 10px 5px;
    overflow: hidden;
    position: relative;
}
a:visited,a:active,a:link{
  color:#000;
  text-decoration:none;  
}
.home-link a:visited,.home-link a:active, .home-link a:link {
  text-decoration:none;
  color:#fff;
}
.home-link a:hover {
  text-decoration:none;
  color:#c9c;
}

.header-icon {
    background: url("../images/header_icon.png") no-repeat scroll left top transparent;
    height: 43px;
    margin: 10px 16px;
    position: absolute;
    width: 36px;
}
#header h2 {
    bottom: 12px;
    color: #ECEFDA;
    font-size: 20px;
    left: 64px;
    position: absolute;
}
	
#usernav {
   float:right;
   background:#903;
   color:#fff;
   position:relative;
   font-size:.8em;
   font-weight:bold;
}
#usernavlinks li{
  	float:left;
  	list-style:none;
  	padding:.4em;
  	border-right:1px solid #505050;
}
#footer
{
	border-top:.5em solid #903;
	background: #000;
	color:#fff;	
	height: 30px;
	text-align:right;
	margin:.4em;
	padding:.5em 1em .2em .2em;
	display:block;
}
#title
{
	background: #505050 url(../images/header_icon.png) no-repeat 20px 100%;
	font-size:2em;
    color:#fff;
	padding: 10px 30px 10px 60px;
	margin: 0;
}
#title H1 
{
	font-size: 18px;
	letter-spacing: -1px;
}
#title H1 A
{	
	text-decoration: none;
	color: #4183C4;
}
#title H1 B
{
	padding: 0 5px;
}
#title H1 A.active
{
	font-weight: bolder;
}
#title H1 A:hover
{
	text-decoration: underline;
}
#navbar {
  margin:0em .5em .5em .5em;
  padding:.4em;
  background:#ccc;
  border-top:.5em solid #903;
  border-bottom:.5em solid #903;	
}

/*Left Navigation*/
#left_navigation {
margin-left:.5em;
}
.box-outer-border {
	backgroundx:#BBBBBB url("images/ui-bg_highlight-soft_75_cccccc_1x100.png") repeat-x scroll 50% 50%;
    background: none repeat scroll 0 0 #BBBBBB;
    border-radius: 5px 5px 5px 5px;
    margin-bottom: 10px;
    padding: 35px 8px 1px;
    position: relative;
}
.box-outer-border h1 {
    color: #505050;
    font-size: 18px;
    left: 15px;
    position: absolute;
    top: 10px;
}
.box-inner-border {
    background: none repeat scroll 0 0 white;
    border: 1px solid #C8C8C8;
    border-radius: 5px 5px 5px 5px;
    margin-bottom: 8px;
    position: relative;
    padding:10px;
    display:block;
}
.box-grid-row{
  clear:right;
  
}
.box-grid-two-col{
  float:left;
  width:400;
}
.box-padding {
  padding:20px;	
}
.box-grid-horizontal-border {
    border-top: 1px solid #C8C8C8;
}
.box-grid-row {
    position: relative;
}
.box-break {
  clear:both;
}
.box-grid-big-icon {
    padding-left: 60px;
    position: relative;
}
.box-grid-big-icon .big-icon {
    left: 0;
    position: absolute;
    top: 4px;
}
.box-grid-vertical-border {
    border-left: 1px solid #C8C8C8;
    height: 100%;
    overflow: hidden;
    position: absolute;
    right: 50%;
    top: 0;
    width: 0;
}
#loading
{
  background:url(../images/loading.gif) no-repeat 50% 50% #000;
  opacity:.80;
  width:100%;
  height:100%;
  text-align:center;
  
}
.tab_main
{
  width:700px;
  float:left;
}
.tab_main  table
{
  padding-top:10px;
}
.tab_right
{ 	
  position:absolute;
  float:left;
  width:400px;
  margin-left:660px;
  padding-left:10px;
}

#analyze_options .form-label {display:inline-block; width:300px;padding-right:4px;}
#analyze_options input.text,textarea{width:460px;}
#analyze_options div.entry{margin-bottom:8px}

#document-stats {display: inline-table;float:right;}
#db-stats {border:1px solid #bbb;width:200px;}
#db-stats td{padding:2px;  border-bottom:1px solid #bbb;}
#db-stats td.stat-label {  width:80%;  	}

#document-stats {text-align:right;}
#document-stats td{padding:2px;  border-bottom:1px solid #bbb;}
#document-stats td.stat-label {  width:80%;  	}

#inner-north,#inner-south,#inner-center{overflow:hidden;}
#inner-east{margin:1px;padding:1px;}
#inner-north{margin:1px;padding:1px;}
#inner-content{margin:1px;padding:1px;}
#nav-center, #nav-north,#nav-south {overflow:hidden;width:100%; margin:1;}
#analysis_xpath{min-width:600;width:60%}
#pg {width:20px;}

/*Transform View*/
#transform-north,#transform-south,#transform-center{overflow:hidden;}
#transform-north{margin:1px;padding:1px;}
#transform-east{margin:1px;padding-left:5px;width:33%;overflow:hidden}
#transform-west{margin:1px;padding-left:5px;width:33%;overflow:hidden}
#transform-center{margin:1px;padding:1px;width:33%}


div.ui-layout-pane {padding:0; }
.node-element {display:inline-block;color:blue;}
.node-attribute{display:inline-block;color:#c30;}
.node-element span.ui-icon {padding-left:18px;display:inline;}

/*Coverage View*/
#coverage-toolbar table td{
  vertical-align:middle;
  border:1px;
  padding:4px;
}
#coverage-toolbar .ui-button{font-size:12px;}
#coverage-toolbar .qq-upload-list{display:none;visibility:hidden;}

#inner-east-tabs .ui-tabs-panel{padding:0}