     }); 
     //Initialize Tabs
     $("#analyis_properties").tabs({});
	 $("#coverage-center").tabs({});
	 $("#analyze_options_tabs").tabs({});
	 $("#inner-east-tabs").tabs({});
	 
	 outerLayout = $('body').layout({
		    resizeWithWindowDelay:250,
			west__showOverflowOnHover: true,
			content__spacing_open:0,
