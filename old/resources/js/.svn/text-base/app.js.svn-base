			  size:50,
			  spacing_open:0
			},
		    south: {
		      paneSelector : '#footer',
			  resizable:false,
			  closable:false,
			  height:100,
			  spacing_open:0
			},
			west:{
			  paneSelector : '#left_navigation',
			  size:250,
			  onresize:resizeAnalysisGrids
			}		
		});
    contentLayoutSettings = {
         center__paneSelector:	"#inner-content",
		 east__paneSelector  :   "#inner-east" ,
		 north__paneSelector :   "#inner-north",
		 south__paneSelector :   "#inner-south", 
		 north__spacing_open:0,
		 east__size:370,        //add 20 for scroll
		 north__size:50,
		 south__size:100,
		 onresize: resizeAnalysisGrids,
		 onclose : resizeAnalysisGrids,
		 onopen  : resizeAnalysisGrids
	};
    jQuery("#analysis").layout(contentLayoutSettings);
  
    initializeAnalysisGrid();
    initializeNamespaceOptionsGrid();
    resizeAnalysisGrids();
	  
	coverageLayoutSettings = {
          center__paneSelector:	 ".coverage-center",
		  east__paneSelector  :  ".coverage-east" ,
		  west__paneSelector  :  ".coverage-west" ,
          north__paneSelector :  ".coverage-north",
		  south__paneSelector :  ".coverage-south", 
		  north__spacing_open:0,
		  north__size:50,
		  south__size:400,
		  north__resizable:false,
          north__closable :false,
          onresize: resizeAnalysisGrids,
          onclose:resizeAnalysisGrids,
          onopen: resizeAnalysisGrids
          
	  };
      jQuery("#coverage_view").layout(coverageLayoutSettings);
      initializeCoverage();

      //initialize CodeMirror Editor
      editor =  CodeMirror.fromTextArea(document.getElementById("constraint_query"), {
            lineWrapping: true,
            matchBrackets: true,
