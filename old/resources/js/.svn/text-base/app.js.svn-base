	   	colModel:[
	   	    { name:'key', index:'key',xmlmap:'key', resizable: true, sortable: false,hidden:true},
            { name:'parent', index:'parent',xmlmap:'parent', resizable: true, sortable: true, formatter:nodeFormatter},
            { name:'element', index:'element',xmlmap:'element', resizable: true, sortable: true},
            { name:'parent-variation',index:'parent-variation', xmlmap:'parent-variation', resizable: true,  sortable: true,width:'80',align:'right'},
            { name:'parent-frequency',index:'parent-frequency', xmlmap:'parent-frequency', resizable: true,  sortable: true,width:'80',align:'right'},
            { name:'parentchild-variation',index:'parentchild-variation', xmlmap:'parentchild-variation', resizable: true,  sortable: true,width:'80',align:'right'},
            { name:'parentchild-frequency',index:'parentchild-frequency', xmlmap:'parentchild-frequency', resizable: true,  sortable: true, width:'80',align:'right' }
     	],
	   	xmlReader: {
		  root: "items",
	      row: "item",
	      repeatitems: false,
	      id: "key"
		},
		pager: jQuery("#coverage_pager"),
	 	rowNum:99999999,
	 	rownumbers:true,
	   	multiselect: true,
	   	emptyrecords: "No Documents Found",
	   	gridview: true,
	   	loadonce: false,
	   	viewrecords:true,
		onSelectRow: function(id) {
	   	   
	    }
  })  
  .navGrid('#coverage_pager',{edit:false,add:false,del:false,search:true, reload:true})
  .navButtonAdd('#coverage-pager',{
       title: "Columns",
       caption:"", 
       buttonicon: "ui-icon-calculator",    
       onClickButton:function() {
        $("#coverage_table").jqGrid("columnChooser");
        resizeCoverageGrid();
       }
  }) 
 .trigger("reloadGrid");
 resizeCoverageGrid(); 
}


function resizeCoverageGrid() {
     jQuery("#coverage_table").setGridWidth($("#coverage-center").width() -10);
     jQuery("#coverage_table").setGridHeight($("#coverage-center").height() - 100); 
}

function runCoverage(){
  $.blockUI();
  var analysis = $("#coverage_source").val();
  var schemaUri = $("#coverage_schemas").val();  
  $("#coverage_table").jqGrid('setGridParam',{
    	 url:'/services/schema-service.xqy?action=coverage&analysis=' + analysis  + '&schema=' + schemaUri,
    	 method:'post'
  }).trigger('reloadGrid');
  
  if(analysis != "" && schemaUri != "") {
       $.ajax({
            url:'/services/schema-service.xqy',
            method:'post',
            data : {action:'coverage', 'analysis':analysis,'schema':schemaUri },
            success :function(response){
                var categories = [];
                var series1 = [];
                var series2 = [];
                $(response).find("items").find("item").each(function(index,elem){
                     categories.push($(elem).find("element").text());
                     series1.push(parseInt($(elem).find("parent-frequency").text()));
                     series2.push(parseInt($(elem).find("parentchild-frequency").text()));
                });
                var seriesdata  = 
                [ 
                  {name:'schema',  data : series1 }, 
                  {name:'element', data : series2 }
                ]
                var data = {
                  schema: schemaUri,
                  categories : categories,
                  series : seriesdata
                }
                initializeCoverageGrid();
                initializeCoverageChart(data);
                $.unblockUI();
            }            
      });
  } else {
     $.unblockUI();
     alertPretty("Please Select Analysis and Schema before running Coverage");
  }
}
function exportCoverage(){
  var analysis = $("#coverage_source").val();
  var schemaUri = $("#coverage_schemas").val();
  window.location.href = '/services/schema-service.xqy?export=true&action=coverage&analysis=' +analysis + '&schema=' + schemaUri;
}

function loadDatabases()
{    
    $.ajax({
      method:'post',
      url:'/services/databases.xqy',
      success: function(response){
    	  var sb = "";
    	  $(response).find("database").each(function(){
    		 if($(this).text() == '') 
    		 sb += "<option value=''>Select a Database</option>";
             
    		 sb += "<option value=\"" + $(this).text() +"\">" + $(this).text() +"</option>";
                    		 
    	  });
    	  $("#databases").html(sb);
    	  $('#databases').cookieFill();
    	  if($('#databases').val() != "") {
    	      db = $("#databases").val();
    	      updateRootElementsGrid();
    	      initializeRootElementsGrid(); 
    	      updateExpressionList();
    	      updateStats();
              updateAnalysisStatistics();
              updateNamespaceOptionsGrid();
    	  }
      } 	
    });
}
function initializeCoverage()
{
    initializeCoverageGrid();
    var uploaderTerm = new qq.FileUploader({
         element: $('#schema_upload_holder')[0],
         action: '/services/schema-service.xqy',
         params: {action:'upload',name: name},
         allowedExtensions: ['xsd'],
         onSubmit: 
        	 function(id,fileName){
        	 	var fileExists = $("#coverage_schemas option").filter(":contains(" + fileName + ")").val();
        	 	var bReturn = false;
        	 	if(fileExists == null || fileExists == undefined || fileExists == "")
        	    {
        	 	   bReturn = true;
        	    }
        	 	else {
         	 	   bReturn = confirm("Xml Schema Already Exists. Overwrite?");
         	 	   
        	 	}
        	 	return bReturn;
         	 },
         onComplete: 
             function(id, fileName, response){
     	 	     var fileExists = $("#coverage_schemas").filter(":contains(" + fileName + ")").val();
     	 	     var fileUri = $(response).find("uri").text();
     	 	     if(fileExists == undefined || fileExists == ""){
	                 $("#coverage_schemas").append("<option value='"+fileUri + "'>" + fileUri + "</option>");
     	 	     }
     	 	     $("#coverage_schemas option").filter(':contains('+ fileUri + ')').attr("selected","selected");
             }
     }) 
}


//Document Load
$(window).bind("load", function() {   
    //Block UI to load initial pages  
    $(document).ajaxStart($.blockUI()).ajaxStop($.unblockUI);
    
    loadDatabases(); 
    $("#databases").change(function(){
        db = $("#databases").val();  
        $("#databases").cookify();        
        updateStats();
        updateAnalysisStatistics();
        updateNamespaceOptionsGrid();
        updateExpressionList();
        updateRootElementsGrid() ;
    	viewHome();
    	
    });
    $("#expression_list").change(function() {
        loadExpression();
    });
	//Initilaize validate button
	$("#validate_expression").button().click(function(){
	    validateExpression();
	  });
	 $("#format_expression").button().click(function(){
	    formatExpression();
	  });
	 $("#execute_expression").button().click(function(){
	    executeExpression();
	  });
	  $("#copy_expression").button().click(function(){
	    copyExpression();
	  });
	  $("#save_expression").button().click(function(){
	    saveExpression();
	  });
	  $("#delete_expression").button().click(function(){
	    deleteExpression();
	  });
	  $("#export-analysis").button({
	    icons: {primary:'ui-icon-extlink'}
	  });
	  $("#delete-analysis").button({
	    icons: {primary:'ui-icon-trash'}
	  });
	  $("#delete-analysis").button();
	  
	  $("#query").click(function(){
		 executeXpath();
	  });
          
      
      $("#ps").change(function(){
         $("#pg").val(1);
    	 executeXpath();
	  });
	  
	 // Initialize Export Click
     $("#export-analysis").click(function(){
        doAnalysisExport();
     });
     $("#delete-analysis").click(function() {
