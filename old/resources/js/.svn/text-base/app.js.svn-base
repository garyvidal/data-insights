//View Coverage 
function viewCoverage(){
  $.blockUI();
  $("#home").hide();
  $("#distribution").hide();
  $("#analysis").hide();
  $("#transform").hide();
  $("#coverage_view").hide();
  $("#run-coverage").button({icons: {primary: "ui-icon-play"}});
  $("#export-coverage").button({icons : {primary: "ui-icon-extlink"}});
  $.ajax({
	  url:"/services/get-analysis-list.xqy",	
	  data:{db:$("#databases").val()},	
	  success:function(resp){
	    $("#coverage_source").empty();
	    if($(resp).find("analysis-list").length > 0) {	
	         $(resp).find("analysis").each(function(){
				 var tabname = $(this).find("localname").text();
				 var tabid = $(this).find("analysis-id").text();
				 var title = $(this).find("analysis-name").text();
				 var opt= "<option value='" + tabid +"'>" + tabname + " (" + title + ")" +"</option>";
				 $("#coverage_source").append(opt); 
			 });
			 $("#coverage_schemas").empty();
			 $.ajax({
			     url:'/services/schema-service.xqy',
			     data: {action:'list'},
			     success: function(r){
			         $(r).find("schema-uri").each(function(index,elem){
			            var schuri  = $(elem).text();
			            var sopt = "<option value='" + schuri +"'>" + schuri + "</option>";
				        $("#coverage_schemas").append(sopt); 
			         });
			     }
			 });
			 $.unblockUI();
			 $("#coverage_view").show();
			 
	    } else {
	    	alertPretty("Database has not been analyzed or is empty");
	    	viewHome();
	    	$.unblockUI();
	    }
	  }	
	});
}

function initializeCoverageChart(data)
{
    var chart;
    
    $("#coverage-chart").html("");
    chart = new Highcharts.Chart({
          colors: ['#000000','#00FF00'],

          chart: {
             renderTo: 'coverage-chart',
             defaultSeriesType: 'column',
             zoomType:'x',
             reflow:true
          },
          title: {
             text: 'Schema Coverage Analysis ' + data.schema 
          },
          xAxis: {
             categories: data.categories,
             labels: {
                rotation: -66,
                align: 'right',
                style: {
                   font: 'normal 12px Verdana, sans-serif',
                   color: (Highcharts.theme && Highcharts.theme.textColor) || 'gray'
                }
             }
          },
          yAxis: {
             min: 0,
             max: 100,
             title: {
                text: 'Schema Coverage (Frequency/Occurrence)'
             },
             stackLabels: {
                enabled: false,
                style: {
                   fontWeight: 'bold',
                   color: (Highcharts.theme && Highcharts.theme.textColor) || 'gray'
                }
             }
          },
          tooltip: {
            formatter: function() {
                return ''+
                this.x +': '+ this.y +' ('+ Math.round(this.percentage) +'%)';
             }
          },
          plotOptions: {
             column: {
                stacking: 'percent',
                pointPadding: 0,
                groupPadding: 0,
                borderWidth: .1,
                shadow: false
             }
          },
           series:data.series
       });
           
       $("#coverage-chart").click( function() {
                chart.xAxis[0].setExtremes(6, 10); 
       });
}

