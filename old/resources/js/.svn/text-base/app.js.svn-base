}

function gridDimensions(){	
	var innerWidth =  $("#header").innerWidth() - $("#left_navigation").outerWidth() - 200;
	var innerHeight = $('#footer').height() - $("#header").height() - 120;  
	var opts = 
	{
     'width' : innerWidth,
     'height' : innerHeight 
	};
	return opts;
}
/*
 * Runs an analysis against database
*/
function analyzeDatabase()
{
    var db = $("#databases option:selected").val();
    $("#analyze_options_db").html(db);
    
    $("#analyze_options").dialog({
       width:'800',
       resizable:false,
       modal:true,
       buttons: {
            "Run Analysis": function () {
                doAnalysis ();
                $(this).dialog('close');
            },
            "Cancel" : function () {
                $(this).dialog('close');
                viewHome();
                return false;
            }
        }
    });
    //Make CodeMirror display properly on dialog display
    //https://github.com/marijnh/CodeMirror/issues/71
    xpathEditor.refresh();
    editor.refresh();
}

function doAnalysis() {
 var db = $("#databases option:selected").val();
    var params = 
    {
       db:db,
       name : $("#analysis-name").val(),
       sample:$("#sample").val(),
       constraint : editor.getValue(),
       xpath: xpathEditor.getValue(),
       all: $("#select_all").attr("checked"),
       root_elements : $("#select_root_elements").getGridParam('selarrrow')
    };
    $.ajax({
      method:'post',	
      url:'/services/analyze-database.xqy',
      data:params,
      success: function(response)
      {
         $.gritter.add({
	    		title: "Analysis Running",
	    		text: "Analysis of " + db + " has started <br/><a href='' onclick='$.gritter.removeAll();'>Clear Messages</a>" ,
	    		sticky: true,
	    		time: 2000
	    	});   
            notificationStart(); 	    	
      },
      error: function(response) {
        alertPretty(response.responseText);
      }
      
    });
}

function notificationStart()
{
	//Add Notification Polling
	$.ajaxPollSettings.pollingType = "timed";
	$.ajaxPollSettings.interval = 5000;
	$.ajaxPollSettings.maxInterval = 1000;
	$.ajaxPollSettings.durationUntilMaxInterval = 6000;
	$.ajaxPoll({
	    url: "/services/notifications.xqy",
	    type: "POST",
	    data: { queryId: 1234 },
	    dataType: "xml",
	    successCondition : function(data) {
	      $(data).find("notification").each(function(){
	    	$.gritter.add({
	    		title: $(this).find("title").text(),
	    		text: $(this).find("message").text(),
	    		sticky: false,
	    		time: 3000
	    	});   
	      });
	      return $(data).find("status").text() == "Complete";
	    },
	    success: function(data) {
	    	$.gritter.add({
	    		title: $(data).find("title").text(),
	    		text: $(data).find("message").text(),
	    		sticky: false,
	    		time: 3000
	    	}); 
	    }
	});
}
/*
Formats Node Names
*/
function nodeFormatter(cellValue,options,row) 	
{
    var level = "0";
    var isLeaf = false;
    var elemClass = "";
    if(row.level == undefined) {
       level = $(row).find("level").text();
    } else {
       level = row.level;
    }
    if(row.isLeaf == undefined) {
       isLeaf = $(row).find("isLeaf").text() == "true";
    }else {
       isLeaf = row.isLeaf == "true";
    }
    if(isLeaf) {elemClass += "ui-icon ui-icon-minus"} else {elemClass += "ui-icon ui-icon-carat-1-s"}
    var depth = parseInt(level) * 20;
    var indent = "padding-left:" + depth + 'px';
    
  	if(cellValue.startsWith("@")){
  		return "<div class='node-attribute' style='" +  "'>" + cellValue  + "</div>";
  	}
  	return     "<div class='node-element' style='" +  "'>" + cellValue  + "</div>";
}

/*
Formats Name column
*/
function elementFormatter(cellValue,options,row) 	
{
    var level = "0";
    var isLeaf = false;
    var elemClass = "";
    if(row.level == undefined) {
       level = $(row).find("level").text();
    } else {
       level = row.level;
    }
    if(row.isLeaf == undefined) {
       isLeaf = $(row).find("isLeaf").text() == "true";
    }else {
       isLeaf = row.isLeaf == "true";
    }
    if(isLeaf) {elemClass += "ui-icon ui-icon-minus"} else {elemClass += "ui-icon ui-icon-carat-1-s"}
    var depth = parseInt(level) * 20;
    var indent = "padding-left:" + depth + 'px';
    
  	if(cellValue.startsWith("@")){
  		return "<div class='node-attribute' style='" + indent +  "'><span/>" + cellValue  + "</div>";
  	}
  	return     "<div class='node-element' style='" + indent + "'><span class='" + elemClass +  "'/>"  + cellValue  + "</div>";
}

function viewAnalysis()
{
	$.blockUI({message:'<p><img src="/resources/images/loading.gif"></img>Getting Analysis Data...</p>'});
	
	$("#home").hide();
	$("#analysis").hide();
	$("#distribution").hide();
	$("#transform_view").hide();
	$("#analysis_elements").html("");

	root_elements = [];
	var data = {db:db};
	$.ajax({
	  url:"/services/get-analysis-list.xqy",	
	  data:data,	
	  success:function(resp){
	    if($(resp).find("analysis").length > 0)
	    {	
	     var id = $("#analysis_elements").val();
	     $(resp).find("analysis").each(function()
			 {
				 var tabname = $(this).find("localname").text();
				 var tabid = $(this).find("analysis-id").text();
				 var aname = $(this).find("analysis-name").text();
				 root_elements.push({name:tabname,id:tabid});
				 var opt= "<option value='" + tabid +"'>" + tabname + "[" + aname + "]" +"</option>";
				 $("#analysis_elements").append(opt); 
			 });
			 $("#analysis_elements").change(function(){
			   
			    updateNamespaces($(this).val());
			    refreshAnalysisGrid($(this).val());
			    
			 });
			 var analysisId  = $("#analysis_elements").val();
			 updateNamespaces(analysisId);
             refreshAnalysisGrid(analysisId);
             //var rootSelected = $("#analysis_elements option:selected").text()
			 //rootElement = rootSelected.substring(0 , rootSelected.indexOf(" "))

			 $.unblockUI();
			 $("#analysis").show();
	    } else {
	    	alertPretty("Database has not been analyzed or is empty");
	    	viewHome();
	    	$.unblockUI();
	    }
	  }	
	});
}

function clearAnalysisDatabase() {
   confirmPretty("Are you sure you want to clear analyses for database [" + db + ']' ,
   function() {
    $.ajax({
      url:'/services/clear-db.xqy',
      data: {db:db},
      success : function(response) {
         alertPretty("Cleared Database Analaysis");
         updateAnalysisStatistics();
         viewHome();
      }
    });
  });
};

function deleteAnalysis() {
   var analysisId = $("#analysis_elements").val();
   confirmPretty("Are you sure you want to delete analysis",
   function() {
        $.ajax({
            url:'/services/delete-analysis.xqy',
            data: {id:analysisId},
            success:function(response) {
                var selected = $("#analysis_elements option:selected");
                selected.remove();
                if($("#analysis_elements option").length == 0){
                    viewHome();
                } else {
                var nextId  = $("#analysis_elements").val();
                updateAnalysisStatistics();
			    updateNamespaces(nextId);
                refreshAnalysisGrid(nextId);
                }
                alertPretty("Analysis has been deleted");
            }
        }); 
   });
}

function refreshAnalysisGrid(id)
{
     $("#namespace_table").jqGrid('setGridParam',{
   		        url:'/services/get-analysis.xqy?type=structure&analysis-id=' + id
   	 }).trigger('reloadGrid'); 
   	 
	 $("#analysis_table").jqGrid('setGridParam',{
	   	 url:'/services/get-analysis.xqy?type=structure&analysis-id=' + id  + '&db=' + db
   	 }).trigger('reloadGrid');
   	 
   	 
	 $("#uris_table").jqGrid('setGridParam',{
	   	 url:'/services/get-analysis.xqy?type=uris&analysis-id=' + id  + '&db=' + db
   	 }).trigger('reloadGrid');
   	 
   	 $("#analysis_xpath").val("");
     getDocumentStatistics(id);
}

function refreshDatabaseStatistics() {
    var db = $("#databases option:selected").val();
    getDocumentStatistics(db);
}

function getDocumentStatistics(id){
 $.ajax({
     url:'/services/get-analysis.xqy',
     data: {type:'document-stats',db:db,"analysis-id"   :id},
     success : function(response) {
        var avg = $(response).find("avg-document-size").text();
        var min = $(response).find("min-document-size").text();
        var max = $(response).find("max-document-size").text();
        var med = $(response).find("median-document-size").text();
        
        $("#doc-avg").html(fileSizeFormat(avg));
        $("#doc-min").html(fileSizeFormat(min));
        $("#doc-max").html(fileSizeFormat(max));
        $("#doc-mode").html(fileSizeFormat(med));
     }
   });
}

