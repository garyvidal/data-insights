function doAnalysisExport() {
  var id = $("#analysis_elements").val();
  window.location.href = '/services/get-analysis.xqy?type=export&analysis-id=' + id ;
}

function formatXPath(xpath) {
   var formatted = xpath.replace('\"','&dquot;').replace("'","&quot;");
   return formatted;
}

function resizeAnalysisGrids()
{
    //Resize Property Center
    //jQuery("#property-center").width(jQuery("#property-north").width());
    //jQuery("#property-north-resizer").width(jQuery("#property-north").width());
    
    //Refactor for resize
    jQuery("#analysis_table").setGridWidth($("#inner-content").width());
    jQuery("#analysis_table").setGridHeight($("#inner-content").height() - 80);
    
    //Resize Grids in Tabs
    jQuery("#namespace_table").setGridWidth($("#inner-east").width() -10);
    jQuery("#namespace_table").setGridHeight($("#inner-content").height() - $("#inner-east-tabs ul.ui-tabs-nav").height() - 40);
   
   //Resize Grids in Tabs
    jQuery("#uris_table").setGridWidth($("#inner-east").width() -10);
    jQuery("#uris_table").setGridHeight($("#inner-content").height() - $("#inner-east-tabs ul.ui-tabs-nav").height() - 40);
    
    jQuery("#analysis_values").setGridWidth($("#inner-east").width() -10);
    jQuery("#analysis_values").setGridHeight($("#inner-content").height() - $("#inner-east-tabs ul.ui-tabs-nav").height() - 82);

    jQuery("#xpath_table").setGridWidth($("#inner-east").width() -10);
    jQuery("#xpath_table").setGridHeight($("#inner-content").height() - $("#inner-east-tabs ul.ui-tabs-nav").height() - 60);

    
    if(xpathResults != null) {
        jQuery("#inner-south .CodeMirror-scroll").height(jQuery("#inner-south").height() - jQuery("#xpath_header").height());
    }
}
