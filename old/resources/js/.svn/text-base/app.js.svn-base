function rootElementIndex()
{
	$.blockUI();
	$("#home").hide();
	$("#analysis").hide();
	$("#content-form").hide();
	$("#distribution").hide();
	$("#coverage_view").hide();
    resetGrid();
    $("#listChart").html("");
	$("#content_list_header").html("Database:(" + $("#databases").val() + ") Content Distribution");
    $("#content_form_header").html($("#databases").val() + "Content Distribution");
    var db = $("#databases option:selected").val();
	$("#list_grid").jqGrid({
	   	url:'/services/root-elements.xqy?db=' + db,
		datatype: "xml",
	   	colNames:['ID', 'Type','Element Name',"Namespace","Number of Documents"],
	   	colModel:[
   	         { name:'id', index:'id',xmlmap:'id', resizable: false, sortable: false,hidden:true },
		     { name:'type',index:'type', xmlmap:'type', resizable: true,  sortable: true, width:'100'},
		     { name:'localname',index:'localname', xmlmap:'localname', resizable: true,  sortable: true, width:'100'},
   	         { name:'namespace', index:'namespace',xmlmap:'namespace', resizable: true, sortable: true, width:'100' },
   	         { name:'frequency', index:'frequency',xmlmap:'frequency', resizable: true, sortable: true,align:'right',width:'100' }
     	],
	   	xmlReader: {
		root: "root-elements",
	    row: "root-element",
		   repeatitems: false,
		   id: "id"
		},
		//caption:"Root Elements",
	 	rowNum:100,
	   	pager: jQuery('#list_grid_pager'),
	   	multiselect: false,
	   	emptyrecords: "No Documents Found",
	   	sortname: 'name',
	   	gridview: true,
	   	sortorder: "desc",
	   	loadonce: false,
	   	width:  gridDimensions().width - 100,
	   	height: gridDimensions().height,
	   	loadComplete : function(data){
	      //Load the Chart Data
	      var element_data = [];
	      var binary_data = [];
	      var node_data = [];
	      var esum = 0,  bsum = 0, nsum = 0;
	      $(data).find("root-element").each(function(){
	    	if($(this).find("type").text() == "element"){ 
	    	   esum += parseInt($(this).find("frequency").text()); 
	    	} else if($(this).find("type").text() == "binary") {
	    	   bsum += parseInt($(this).find("frequency").text());
	    	}
	    	nsum += parseInt($(this).text());
	      });
	      $(data).find("root-element").each(function(){
	           if($(this).find("type").text() == "element") {
        	    	element_data.push({
   		                name : $(this).find("localname").text(), 
        	            frequency : $(this).find("frequency").text(),
                        x : Math.round((parseInt($(this).find("frequency").text())  / esum) * 1000) / 1000,
        	    		y : parseInt($(this).find("frequency").text())
        	    	})
        	    	}else {
        	    	  binary_data.push({
        	    		name : $(this).find("localname").text(),
        	    		frequency : $(this).find("frequency").text(),
        	    		x : Math.round((parseInt($(this).find("frequency").text())  / bsum) * 1000) / 1000,
        	    		y : parseInt($(this).find("frequency").text())
        	    	})   
        	    	node_data.push({
        	    		name : $(this).find("type").text(),
        	    		frequency : $(this).find("frequency").text(),
                        x : Math.round((parseInt($(this).find("frequency").text())  / nsum) * 1000) / 1000,
        	    		y : parseInt($(this).find("frequency").text())
        	    	})        	    	
	    	  }
	    	  
	      });
	      renderChart("elementChart",  [{
	          width:200,
	    	  type:'pie',
	    	  name:'Xml Content Distribution',
	    	  data : element_data
	      }]);
	      renderChart("binaryChart",  [{
	    	  type:'pie',
	    	  name:'Binary Content Distribution',
	    	  data : binary_data
	      }]);
        $("#distribution").show();
	    $.unblockUI();
	   	}
  })
  .navGrid('#list_grid_pager',{edit:false,add:false,del:false,search:false, reload:true});
}

function renderChart(id, series)
{
	//Render Pie Chart
  var chart = 
	  new Highcharts.Chart({
		      chart: {	
		         renderTo: id,
		         plotBackgroundColor: null,
		         plotBorderWidth: null,
		         plotShadow: false,
		         size:150
		      },
		      title: {
		         text: series[0].name
		      },
		      tooltip: {
		         formatter: function() {
		            return '<b>'+ this.point.name +'</b><br/>Count:' + this.point.frequency + ' (' + Math.round((this.point.x * 100))  + ' %)';
		         }
		      },
		      plotOptions: {
		         pie: {
		            allowPointSelect: true,
		            cursor: 'pointer',
		            dataLabels: {
		               enabled: false,
		               color: Highcharts.theme.textColor || '#000000',
		               connectorColor: Highcharts.theme.textColor || '#000000',
		               formatter: function() {
		                  return '<b>'+ this.point.name +'</b>: '+ Math.round(this.percentage*10)/10 +' %';
		               }
		            }
		         }
		      },
		      series: series
	   });
}



function viewHome()
{
  $("#home").show();
  $("#distribution").hide();
  $("#analysis").hide();
  $("#transform").hide();
  $("#coverage_view").hide();
}

function validateExpression(){
   $.ajax({
      method:'POST',
      dataType:'xml',
      url:"/services/validate-query.xqy",
      data:{
          db : $("#databases").val(),
          constraint : editor.getValue()
        , xpath : xpathEditor.getValue()
      },
      success:function(response) {
         var valid = $(response).find("valid").text();
         if(valid == "true") {
            alertPretty("Expression is valid"); 
         }
         else { 
            var error = $(response).find("error").text();
            alertPretty("Expression is not valid " + error);
         }
      }
   });
}  

function updateExpressionList() {
   $("#expression_list").html("");
   $.ajax({
      method:'POST',
      dataType:'xml',
      url:"/services/expressions.xqy",
      data:{
        action: "list",
        db : $("#databases").val()
      },
      success:function(response) {
         $("#expression_list").append("<option value=''>(none)</option>");
         $(response).find("expression").each(function() {
            $("#expression_list").append("<option value='" + $(this).find("id").text() + "'>" + $(this).find("name").text() + "</option>");
         });
      }
   });
}

function formatExpression(){
   $.ajax({
      method:'POST',
      dataType:'xml',
      url:"/services/format-query.xqy",
      data:{
        query : editor.getValue(),
        xpath : xpathEditor.getValue()
      },
      success:function(response) {
         var valid = $(response).find("valid").text();
         if(valid == "true") {  
             editor.setValue($(response).find("query").text());
             xpathEditor.setValue($(response).find("xpath").text());             
         }
         else { 
            var error = $(response).find("error").text();
            alertPretty("Expression is not valid" + "error");}
      }
   });
}

function saveExpression(){

   $("<div title='Save Expression'><label>Expression Name:</label><input id='__NAME__' style='width:150px;'/></div>")
   .dialog({
     title:'Save Expression',
     autoOpen:true,
     modal:true,
     height:150,
     width:400,
     buttons : {
        "Save" : function() {
          var expressionName  = $("#__NAME__").val();
          if(expressionName != '' && expressionName  != null) {
               $.ajax({
                  method:'POST',
                  dataType:'xml',
                  url:"/services/expressions.xqy",
                  data:{
                    action: "save",
                    db : db,
                    query : editor.getValue(),
                    xpath : xpathEditor.getValue(),
                    name : expressionName
                  },
                  success : function(response) {
                    var id = $(response).find("id").text();   
                    $("#expression_list").append("<option value='"+ id+"'>" + expressionName + "</option>");
                    $("#expression_list").val(id);
                  } 
               });
               $("#__NAME__").remove();
               $( this ).dialog( "close" ); 
           }               
        },
        "Cancel" : function() {
            $(this).dialog("close");
        }
     }
 });  
}
function loadExpression() {
   if($("#expression_list").val() != "") {
         $.ajax({
              method:'POST',
              dataType:'xml',
              url:"/services/expressions.xqy",
              data:{
                action: "get",
                id : $("#expression_list").val()
              },
              success : function(response) {
                editor.setValue($(response).find("query").text());
                xpathEditor.setValue($(response).find("xpath").text());
              } 
       });    
   }   
};

function deleteExpression() {
   var id = $("#expression_list").val();
   if(id != "" && id != null) {
      $.ajax({
            method:'POST',
            dataType:'xml',
            url:"/services/expressions.xqy",
            data:{
              action: "delete",
              id : $("#expression_list").val()
            },
            success : function(response) {
              var selected = $("#expression_list option:selected");
              selected.remove();
              $("expression_list").val("");
            } 
     }); 
   } 
}

function executeExpression(){
   $.ajax({
      method:'POST',
      dataType:'xml',
      url:"/services/eval-query.xqy",
      data:{
        query : editor.getValue(),
        xpath : xpathEditor.getValue(),
        db: $("#databases").val()
      
      },
      success:function(response) {
         var valid = $(response).find("valid").text();
         if(valid == "true") {
            $("#expression_estimate").html($(response).find("count").text());
         }
         else { 
            var error = $(response).find("error").text();
            alertPretty("Expression is not valid " + error);}
      }
   });
}

function executeXpath(){
    if($("#analysis_xpath").val() == '') {
        alertPretty("Select a node from data structure grid or valid xpath expression");
        $("#analysis_xpath").effect("highlight", {}, 4000);
        $("#analysis_xpath").focus();
        return;
    }
	$.blockUI({message:'<p><img src="/resources/images/loading.gif"></img>Executing XPath...</p>'});
	$.ajax({
	      method:'POST',
	      dataType:'xml',
	      url:"/services/eval-xpath.xqy",
	      data:{
	        id : $("#analysis_elements").val(),
//	        namespaces : $("#form-namespaces").val(),
	        xpath : $("#analysis_xpath").val(),
	        db: $("#databases").val(),
	        ps: $("#ps").val(),
	        pg: $("#pg").val()
	      },
	      success:function(response) {
	         var valid = $(response).find("valid").text();
	         if(valid == "true") {
	        	var resultXml = $(response).find("result");
                xpathResults.setValue((new XMLSerializer()).serializeToString(resultXml[0]));                
                $.unblockUI();
	         }
	         else { 
	            var error = $(response).find("error").text();
	            alertPretty("Expression is not valid " + error);
	            $.unblockUI();
	         }
	      }
	   });	
}

