     or $state[$p:lk] = 10789447                            (: 'attribute' 'where' '{' :)
     or $state[$p:lk] = 10789468                            (: 'element' 'where' '{' :)
     or $state[$p:lk] = 10789516) then                      (: 'processing-instruction' 'where' '{' :)
      let $state := p:parse-FilterExpr($input, $state)
      return $state
    else if ($state[$p:error]) then
      $state
    else
      let $state := p:parse-AxisStep($input, $state)
