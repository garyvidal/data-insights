              or $state[$p:lk] = 39751) then                (: 'attribute' 'treat' :)
          let $state := p:lookahead3W(84, $input, $state)   (: S^WS | '(.' | 'as' | '{' :)
          return $state
        else if ($state[$p:lk] = 17223                      (: 'attribute' 'div' :)
              or $state[$p:lk] = 22855                      (: 'attribute' 'else' :)
              or $state[$p:lk] = 23879                      (: 'attribute' 'eq' :)
              or $state[$p:lk] = 24903                      (: 'attribute' 'except' :)
              or $state[$p:lk] = 25415                      (: 'attribute' 'ge' :)
              or $state[$p:lk] = 26951                      (: 'attribute' 'gt' :)
              or $state[$p:lk] = 27463                      (: 'attribute' 'idiv' :)
              or $state[$p:lk] = 27719                      (: 'attribute' 'intersect' :)
              or $state[$p:lk] = 29255                      (: 'attribute' 'is' :)
              or $state[$p:lk] = 29511                      (: 'attribute' 'le' :)
              or $state[$p:lk] = 30279                      (: 'attribute' 'lt' :)
              or $state[$p:lk] = 31047                      (: 'attribute' 'mod' :)
              or $state[$p:lk] = 31303                      (: 'attribute' 'ne' :)
              or $state[$p:lk] = 32071                      (: 'attribute' 'or' :)
              or $state[$p:lk] = 33607                      (: 'attribute' 'return' :)
              or $state[$p:lk] = 36423                      (: 'attribute' 'satisfies' :)
              or $state[$p:lk] = 36679                      (: 'attribute' 'to' :)
