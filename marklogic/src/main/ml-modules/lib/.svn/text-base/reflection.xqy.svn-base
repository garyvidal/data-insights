(:~
 : Parse ElementTest.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-ElementTest($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state := p:shift(92, $input, $state)                 (: 'element' :)
  let $state := p:lookahead1W(30, $input, $state)           (: S^WS | '(' | '(.' :)
  let $state := p:shift(30, $input, $state)                 (: '(' :)
  let $state := p:lookahead1W(169, $input, $state)          (: S^WS | QName^Token | '(.' | ')' | '*' | 'ancestor' |
                                                               'ancestor-or-self' | 'and' | 'ascending' | 'attribute' |
                                                               'case' | 'cast' | 'castable' | 'child' | 'collation' |
                                                               'comment' | 'declare' | 'default' | 'descendant' |
                                                               'descendant-or-self' | 'descending' | 'div' |
                                                               'document' | 'document-node' | 'element' | 'else' |
                                                               'empty' | 'empty-sequence' | 'eq' | 'every' | 'except' |
                                                               'following' | 'following-sibling' | 'for' | 'ge' | 'gt' |
                                                               'idiv' | 'if' | 'import' | 'instance' | 'intersect' |
                                                               'is' | 'item' | 'le' | 'let' | 'lt' | 'mod' | 'module' |
                                                               'ne' | 'node' | 'or' | 'order' | 'ordered' | 'parent' |
                                                               'preceding' | 'preceding-sibling' |
                                                               'processing-instruction' | 'property' | 'return' |
                                                               'satisfies' | 'schema-attribute' | 'schema-element' |
                                                               'self' | 'some' | 'stable' | 'text' | 'to' | 'treat' |
                                                               'typeswitch' | 'union' | 'unordered' | 'validate' |
                                                               'where' | 'xquery' :)
  let $state :=
    if ($state[$p:error]) then
      $state
    else if ($state[$p:l1] != 33) then                      (: ')' :)
      let $state := p:parse-ElementNameOrWildcard($input, $state)
      let $state := p:lookahead1W(74, $input, $state)       (: S^WS | '(.' | ')' | ',' :)
      let $state :=
        if ($state[$p:error]) then
          $state
        else if ($state[$p:l1] = 38) then                   (: ',' :)
          let $state := p:shift(38, $input, $state)         (: ',' :)
          let $state := p:lookahead1W(164, $input, $state)  (: S^WS | QName^Token | '(.' | 'ancestor' |
                                                               'ancestor-or-self' | 'and' | 'ascending' | 'attribute' |
                                                               'case' | 'cast' | 'castable' | 'child' | 'collation' |
                                                               'comment' | 'declare' | 'default' | 'descendant' |
                                                               'descendant-or-self' | 'descending' | 'div' |
                                                               'document' | 'document-node' | 'element' | 'else' |
                                                               'empty' | 'empty-sequence' | 'eq' | 'every' | 'except' |
                                                               'following' | 'following-sibling' | 'for' | 'ge' | 'gt' |
                                                               'idiv' | 'if' | 'import' | 'instance' | 'intersect' |
                                                               'is' | 'item' | 'le' | 'let' | 'lt' | 'mod' | 'module' |
                                                               'ne' | 'node' | 'or' | 'order' | 'ordered' | 'parent' |
                                                               'preceding' | 'preceding-sibling' |
                                                               'processing-instruction' | 'property' | 'return' |
                                                               'satisfies' | 'schema-attribute' | 'schema-element' |
                                                               'self' | 'some' | 'stable' | 'text' | 'to' | 'treat' |
                                                               'typeswitch' | 'union' | 'unordered' | 'validate' |
                                                               'where' | 'xquery' :)
          let $state := p:parse-TypeName($input, $state)
          let $state := p:lookahead1W(75, $input, $state)   (: S^WS | '(.' | ')' | '?' :)
          let $state :=
            if ($state[$p:error]) then
              $state
            else if ($state[$p:l1] = 60) then               (: '?' :)
              let $state := p:shift(60, $input, $state)     (: '?' :)
              return $state
            else
              $state
          return $state
        else
          $state
      return $state
    else
      $state
  let $state := p:lookahead1W(31, $input, $state)           (: S^WS | '(.' | ')' :)
  let $state := p:shift(33, $input, $state)                 (: ')' :)
  return p:reduce($state, "ElementTest", $count)
};

(:~
 : Parse DocumentTest.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-DocumentTest($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state := p:shift(91, $input, $state)                 (: 'document-node' :)
  let $state := p:lookahead1W(30, $input, $state)           (: S^WS | '(' | '(.' :)
  let $state := p:shift(30, $input, $state)                 (: '(' :)
  let $state := p:lookahead1W(104, $input, $state)          (: S^WS | '(.' | ')' | 'element' | 'schema-element' :)
  let $state :=
    if ($state[$p:error]) then
      $state
    else if ($state[$p:l1] != 33) then                      (: ')' :)
      let $state :=
        if ($state[$p:l1] = 92) then                        (: 'element' :)
          let $state := p:parse-ElementTest($input, $state)
          return $state
        else if ($state[$p:error]) then
          $state
        else
          let $state := p:parse-SchemaElementTest($input, $state)
          return $state
      return $state
    else
      $state
  let $state := p:lookahead1W(31, $input, $state)           (: S^WS | '(.' | ')' :)
  let $state := p:shift(33, $input, $state)                 (: ')' :)
  return p:reduce($state, "DocumentTest", $count)
};

(:~
 : Parse KindTest.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-KindTest($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state :=
    if ($state[$p:l1] = 91) then                            (: 'document-node' :)
      let $state := p:parse-DocumentTest($input, $state)
      return $state
    else if ($state[$p:l1] = 92) then                       (: 'element' :)
      let $state := p:parse-ElementTest($input, $state)
      return $state
    else if ($state[$p:l1] = 71) then                       (: 'attribute' :)
      let $state := p:parse-AttributeTest($input, $state)
      return $state
    else if ($state[$p:l1] = 146) then                      (: 'schema-element' :)
      let $state := p:parse-SchemaElementTest($input, $state)
      return $state
    else if ($state[$p:l1] = 145) then                      (: 'schema-attribute' :)
      let $state := p:parse-SchemaAttributeTest($input, $state)
      return $state
    else if ($state[$p:l1] = 140) then                      (: 'processing-instruction' :)
      let $state := p:parse-PITest($input, $state)
      return $state
    else if ($state[$p:l1] = 81) then                       (: 'comment' :)
      let $state := p:parse-CommentTest($input, $state)
      return $state
    else if ($state[$p:l1] = 152) then                      (: 'text' :)
      let $state := p:parse-TextTest($input, $state)
      return $state
    else if ($state[$p:l1] = 128) then                      (: 'node' :)
      let $state := p:parse-AnyKindTest($input, $state)
      return $state
    else if ($state[$p:error]) then
      $state
    else
      let $state := p:parse-BinaryTest($input, $state)
      return $state
  return p:reduce($state, "KindTest", $count)
};

(:~
 : Parse ItemType.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-ItemType($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state :=
    if ($state[$p:l1] = 71                                  (: 'comment' :)
     or $state[$p:l1] = 81                                  (: 'document-node' :)
     or $state[$p:l1] = 91                                  (: 'element' :)
     or $state[$p:l1] = 92                                  (: 'item' :)
     or $state[$p:l1] = 116                                 (: 'node' :)
     or $state[$p:l1] = 128                                 (: 'processing-instruction' :)
     or $state[$p:l1] = 140                                 (: 'schema-attribute' :)
     or $state[$p:l1] = 145                                 (: 'schema-element' :)
     or $state[$p:l1] = 146                                 (: 'text' :)
     or $state[$p:l1] = 152) then                           (: 'text' :)
      let $state := p:lookahead2W(158, $input, $state)      (: S^WS | EOF | '!=' | '(' | '(.' | ')' | '*' | '*' | '+' |
                                                               '+' | ',' | '-' | ':=' | ';' | '<' | '<<' | '<=' | '=' |
                                                               '>' | '>=' | '>>' | '?' | ']' | 'and' | 'ascending' |
                                                               'at' | 'case' | 'collation' | 'default' | 'descending' |
                                                               'div' | 'else' | 'empty' | 'eq' | 'except' | 'external' |
                                                               'for' | 'ge' | 'gt' | 'idiv' | 'in' | 'instance' |
                                                               'intersect' | 'is' | 'le' | 'let' | 'lt' | 'mod' | 'ne' |
                                                               'or' | 'order' | 'return' | 'satisfies' | 'stable' |
                                                               'to' | 'union' | 'where' | '{' | '|' | '}' :)
      return $state
    else
      ($state[$p:l1], $state[position() > $p:lk])
  let $state :=
    if ($state[$p:lk] = 73                                  (: 'binary' :)
     or $state[$p:lk] = 7751                                (: 'attribute' '(' :)
     or $state[$p:lk] = 7761                                (: 'comment' '(' :)
     or $state[$p:lk] = 7771                                (: 'document-node' '(' :)
     or $state[$p:lk] = 7772                                (: 'element' '(' :)
     or $state[$p:lk] = 7808                                (: 'node' '(' :)
     or $state[$p:lk] = 7820                                (: 'processing-instruction' '(' :)
     or $state[$p:lk] = 7825                                (: 'schema-attribute' '(' :)
     or $state[$p:lk] = 7826                                (: 'schema-element' '(' :)
     or $state[$p:lk] = 7832) then                          (: 'text' '(' :)
      let $state := p:parse-KindTest($input, $state)
      return $state
    else if ($state[$p:lk] = 7796) then                     (: 'item' '(' :)
      let $state := p:shift(116, $input, $state)            (: 'item' :)
      let $state := p:lookahead1W(30, $input, $state)       (: S^WS | '(' | '(.' :)
      let $state := p:shift(30, $input, $state)             (: '(' :)
      let $state := p:lookahead1W(31, $input, $state)       (: S^WS | '(.' | ')' :)
      let $state := p:shift(33, $input, $state)             (: ')' :)
      return $state
    else if ($state[$p:error]) then
      $state
    else
      let $state := p:parse-AtomicType($input, $state)
      return $state
  return p:reduce($state, "ItemType", $count)
};

(:~
 : Parse SequenceType.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-SequenceType($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state := p:lookahead1(162, $input, $state)           (: QName^Token | 'ancestor' | 'ancestor-or-self' | 'and' |
                                                               'ascending' | 'attribute' | 'binary' | 'case' | 'cast' |
                                                               'castable' | 'child' | 'collation' | 'comment' |
                                                               'declare' | 'default' | 'descendant' |
                                                               'descendant-or-self' | 'descending' | 'div' |
                                                               'document' | 'document-node' | 'element' | 'else' |
                                                               'empty' | 'empty-sequence' | 'eq' | 'every' | 'except' |
                                                               'following' | 'following-sibling' | 'for' | 'ge' | 'gt' |
                                                               'idiv' | 'if' | 'import' | 'instance' | 'intersect' |
                                                               'is' | 'item' | 'le' | 'let' | 'lt' | 'mod' | 'module' |
                                                               'ne' | 'node' | 'or' | 'order' | 'ordered' | 'parent' |
                                                               'preceding' | 'preceding-sibling' |
                                                               'processing-instruction' | 'property' | 'return' |
                                                               'satisfies' | 'schema-attribute' | 'schema-element' |
                                                               'self' | 'some' | 'stable' | 'text' | 'to' | 'treat' |
                                                               'typeswitch' | 'union' | 'unordered' | 'validate' |
                                                               'where' | 'xquery' :)
  let $state :=
    if ($state[$p:l1] = 95) then                            (: 'empty-sequence' :)
      let $state := p:lookahead2W(158, $input, $state)      (: S^WS | EOF | '!=' | '(' | '(.' | ')' | '*' | '*' | '+' |
                                                               '+' | ',' | '-' | ':=' | ';' | '<' | '<<' | '<=' | '=' |
                                                               '>' | '>=' | '>>' | '?' | ']' | 'and' | 'ascending' |
                                                               'at' | 'case' | 'collation' | 'default' | 'descending' |
                                                               'div' | 'else' | 'empty' | 'eq' | 'except' | 'external' |
                                                               'for' | 'ge' | 'gt' | 'idiv' | 'in' | 'instance' |
                                                               'intersect' | 'is' | 'le' | 'let' | 'lt' | 'mod' | 'ne' |
                                                               'or' | 'order' | 'return' | 'satisfies' | 'stable' |
                                                               'to' | 'union' | 'where' | '{' | '|' | '}' :)
      return $state
    else
      ($state[$p:l1], $state[position() > $p:lk])
  let $state :=
    if ($state[$p:lk] = 7775) then                          (: 'empty-sequence' '(' :)
      let $state := p:shift(95, $input, $state)             (: 'empty-sequence' :)
      let $state := p:lookahead1W(30, $input, $state)       (: S^WS | '(' | '(.' :)
      let $state := p:shift(30, $input, $state)             (: '(' :)
      let $state := p:lookahead1W(31, $input, $state)       (: S^WS | '(.' | ')' :)
      let $state := p:shift(33, $input, $state)             (: ')' :)
      return $state
    else if ($state[$p:error]) then
      $state
    else
      let $state := p:parse-ItemType($input, $state)
      let $state := p:lookahead1W(156, $input, $state)      (: S^WS | EOF | '!=' | '(.' | ')' | '*' | '*' | '+' | '+' |
                                                               ',' | '-' | ':=' | ';' | '<' | '<<' | '<=' | '=' | '>' |
                                                               '>=' | '>>' | '?' | ']' | 'and' | 'ascending' | 'at' |
                                                               'case' | 'collation' | 'default' | 'descending' | 'div' |
                                                               'else' | 'empty' | 'eq' | 'except' | 'external' | 'for' |
                                                               'ge' | 'gt' | 'idiv' | 'in' | 'instance' | 'intersect' |
                                                               'is' | 'le' | 'let' | 'lt' | 'mod' | 'ne' | 'or' |
                                                               'order' | 'return' | 'satisfies' | 'stable' | 'to' |
                                                               'union' | 'where' | '{' | '|' | '}' :)
      let $state :=
        if ($state[$p:error]) then
          $state
        else if ($state[$p:l1] = 35                         (: '*' :)
              or $state[$p:l1] = 37                         (: '+' :)
              or $state[$p:l1] = 60) then                   (: '?' :)
          let $state := p:parse-OccurrenceIndicator($input, $state)
          return $state
        else
          $state
      return $state
  return p:reduce($state, "SequenceType", $count)
};

(:~
 : Parse TypeDeclaration.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-TypeDeclaration($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state := p:shift(68, $input, $state)                 (: 'as' :)
  let $state := p:lookahead1W(23, $input, $state)           (: EPSILON | S^WS | '(.' :)
  let $state := p:parse-SequenceType($input, $state)
  return p:reduce($state, "TypeDeclaration", $count)
};

(:~
 : Parse FunctionName.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-FunctionName($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state := p:lookahead1(149, $input, $state)           (: QName^Token | 'ancestor' | 'ancestor-or-self' | 'and' |
                                                               'ascending' | 'case' | 'cast' | 'castable' | 'child' |
                                                               'collation' | 'declare' | 'default' | 'descendant' |
                                                               'descendant-or-self' | 'descending' | 'div' |
                                                               'document' | 'else' | 'empty' | 'eq' | 'every' |
                                                               'except' | 'following' | 'following-sibling' | 'for' |
                                                               'ge' | 'gt' | 'idiv' | 'import' | 'instance' |
                                                               'intersect' | 'is' | 'le' | 'let' | 'lt' | 'mod' |
                                                               'module' | 'ne' | 'or' | 'order' | 'ordered' | 'parent' |
                                                               'preceding' | 'preceding-sibling' | 'property' |
                                                               'return' | 'satisfies' | 'self' | 'some' | 'stable' |
                                                               'to' | 'treat' | 'union' | 'unordered' | 'validate' |
                                                               'where' | 'xquery' :)
  let $state :=
    if ($state[$p:l1] = 65) then                            (: 'ancestor' :)
      let $state := p:shift(65, $input, $state)             (: 'ancestor' :)
      return $state
    else if ($state[$p:l1] = 66) then                       (: 'ancestor-or-self' :)
      let $state := p:shift(66, $input, $state)             (: 'ancestor-or-self' :)
      return $state
    else if ($state[$p:l1] = 67) then                       (: 'and' :)
      let $state := p:shift(67, $input, $state)             (: 'and' :)
      return $state
    else if ($state[$p:l1] = 69) then                       (: 'ascending' :)
      let $state := p:shift(69, $input, $state)             (: 'ascending' :)
      return $state
    else if ($state[$p:l1] = 76) then                       (: 'case' :)
      let $state := p:shift(76, $input, $state)             (: 'case' :)
      return $state
    else if ($state[$p:l1] = 77) then                       (: 'cast' :)
      let $state := p:shift(77, $input, $state)             (: 'cast' :)
      return $state
    else if ($state[$p:l1] = 78) then                       (: 'castable' :)
      let $state := p:shift(78, $input, $state)             (: 'castable' :)
      return $state
    else if ($state[$p:l1] = 79) then                       (: 'child' :)
      let $state := p:shift(79, $input, $state)             (: 'child' :)
      return $state
    else if ($state[$p:l1] = 80) then                       (: 'collation' :)
      let $state := p:shift(80, $input, $state)             (: 'collation' :)
      return $state
    else if ($state[$p:l1] = 84) then                       (: 'declare' :)
      let $state := p:shift(84, $input, $state)             (: 'declare' :)
      return $state
    else if ($state[$p:l1] = 85) then                       (: 'default' :)
      let $state := p:shift(85, $input, $state)             (: 'default' :)
      return $state
    else if ($state[$p:l1] = 86) then                       (: 'descendant' :)
      let $state := p:shift(86, $input, $state)             (: 'descendant' :)
      return $state
    else if ($state[$p:l1] = 87) then                       (: 'descendant-or-self' :)
      let $state := p:shift(87, $input, $state)             (: 'descendant-or-self' :)
      return $state
    else if ($state[$p:l1] = 88) then                       (: 'descending' :)
      let $state := p:shift(88, $input, $state)             (: 'descending' :)
      return $state
    else if ($state[$p:l1] = 89) then                       (: 'div' :)
      let $state := p:shift(89, $input, $state)             (: 'div' :)
      return $state
    else if ($state[$p:l1] = 90) then                       (: 'document' :)
      let $state := p:shift(90, $input, $state)             (: 'document' :)
      return $state
    else if ($state[$p:l1] = 93) then                       (: 'else' :)
      let $state := p:shift(93, $input, $state)             (: 'else' :)
      return $state
    else if ($state[$p:l1] = 94) then                       (: 'empty' :)
      let $state := p:shift(94, $input, $state)             (: 'empty' :)
      return $state
    else if ($state[$p:l1] = 97) then                       (: 'eq' :)
      let $state := p:shift(97, $input, $state)             (: 'eq' :)
      return $state
    else if ($state[$p:l1] = 98) then                       (: 'every' :)
      let $state := p:shift(98, $input, $state)             (: 'every' :)
      return $state
    else if ($state[$p:l1] = 99) then                       (: 'except' :)
      let $state := p:shift(99, $input, $state)             (: 'except' :)
      return $state
    else if ($state[$p:l1] = 101) then                      (: 'following' :)
      let $state := p:shift(101, $input, $state)            (: 'following' :)
      return $state
    else if ($state[$p:l1] = 102) then                      (: 'following-sibling' :)
      let $state := p:shift(102, $input, $state)            (: 'following-sibling' :)
      return $state
    else if ($state[$p:l1] = 103) then                      (: 'for' :)
      let $state := p:shift(103, $input, $state)            (: 'for' :)
      return $state
    else if ($state[$p:l1] = 105) then                      (: 'ge' :)
      let $state := p:shift(105, $input, $state)            (: 'ge' :)
      return $state
    else if ($state[$p:l1] = 107) then                      (: 'gt' :)
      let $state := p:shift(107, $input, $state)            (: 'gt' :)
      return $state
    else if ($state[$p:l1] = 108) then                      (: 'idiv' :)
      let $state := p:shift(108, $input, $state)            (: 'idiv' :)
      return $state
    else if ($state[$p:l1] = 110) then                      (: 'import' :)
      let $state := p:shift(110, $input, $state)            (: 'import' :)
      return $state
    else if ($state[$p:l1] = 113) then                      (: 'instance' :)
      let $state := p:shift(113, $input, $state)            (: 'instance' :)
      return $state
    else if ($state[$p:l1] = 114) then                      (: 'intersect' :)
      let $state := p:shift(114, $input, $state)            (: 'intersect' :)
      return $state
    else if ($state[$p:l1] = 115) then                      (: 'is' :)
      let $state := p:shift(115, $input, $state)            (: 'is' :)
      return $state
    else if ($state[$p:l1] = 118) then                      (: 'le' :)
      let $state := p:shift(118, $input, $state)            (: 'le' :)
      return $state
    else if ($state[$p:l1] = 120) then                      (: 'let' :)
      let $state := p:shift(120, $input, $state)            (: 'let' :)
      return $state
    else if ($state[$p:l1] = 121) then                      (: 'lt' :)
      let $state := p:shift(121, $input, $state)            (: 'lt' :)
      return $state
    else if ($state[$p:l1] = 122) then                      (: 'mod' :)
      let $state := p:shift(122, $input, $state)            (: 'mod' :)
      return $state
    else if ($state[$p:l1] = 123) then                      (: 'module' :)
      let $state := p:shift(123, $input, $state)            (: 'module' :)
      return $state
    else if ($state[$p:l1] = 125) then                      (: 'ne' :)
      let $state := p:shift(125, $input, $state)            (: 'ne' :)
      return $state
    else if ($state[$p:l1] = 131) then                      (: 'or' :)
      let $state := p:shift(131, $input, $state)            (: 'or' :)
      return $state
    else if ($state[$p:l1] = 132) then                      (: 'order' :)
      let $state := p:shift(132, $input, $state)            (: 'order' :)
      return $state
    else if ($state[$p:l1] = 133) then                      (: 'ordered' :)
      let $state := p:shift(133, $input, $state)            (: 'ordered' :)
      return $state
    else if ($state[$p:l1] = 135) then                      (: 'parent' :)
      let $state := p:shift(135, $input, $state)            (: 'parent' :)
      return $state
    else if ($state[$p:l1] = 136) then                      (: 'preceding' :)
      let $state := p:shift(136, $input, $state)            (: 'preceding' :)
      return $state
    else if ($state[$p:l1] = 137) then                      (: 'preceding-sibling' :)
      let $state := p:shift(137, $input, $state)            (: 'preceding-sibling' :)
      return $state
    else if ($state[$p:l1] = 141) then                      (: 'property' :)
      let $state := p:shift(141, $input, $state)            (: 'property' :)
      return $state
    else if ($state[$p:l1] = 142) then                      (: 'return' :)
      let $state := p:shift(142, $input, $state)            (: 'return' :)
      return $state
    else if ($state[$p:l1] = 143) then                      (: 'satisfies' :)
      let $state := p:shift(143, $input, $state)            (: 'satisfies' :)
      return $state
    else if ($state[$p:l1] = 147) then                      (: 'self' :)
      let $state := p:shift(147, $input, $state)            (: 'self' :)
      return $state
    else if ($state[$p:l1] = 148) then                      (: 'some' :)
      let $state := p:shift(148, $input, $state)            (: 'some' :)
      return $state
    else if ($state[$p:l1] = 149) then                      (: 'stable' :)
      let $state := p:shift(149, $input, $state)            (: 'stable' :)
      return $state
    else if ($state[$p:l1] = 154) then                      (: 'to' :)
      let $state := p:shift(154, $input, $state)            (: 'to' :)
      return $state
    else if ($state[$p:l1] = 155) then                      (: 'treat' :)
      let $state := p:shift(155, $input, $state)            (: 'treat' :)
      return $state
    else if ($state[$p:l1] = 157) then                      (: 'union' :)
      let $state := p:shift(157, $input, $state)            (: 'union' :)
      return $state
    else if ($state[$p:l1] = 158) then                      (: 'unordered' :)
      let $state := p:shift(158, $input, $state)            (: 'unordered' :)
      return $state
    else if ($state[$p:l1] = 159) then                      (: 'validate' :)
      let $state := p:shift(159, $input, $state)            (: 'validate' :)
      return $state
    else if ($state[$p:l1] = 162) then                      (: 'where' :)
      let $state := p:shift(162, $input, $state)            (: 'where' :)
      return $state
    else if ($state[$p:l1] = 163) then                      (: 'xquery' :)
      let $state := p:shift(163, $input, $state)            (: 'xquery' :)
      return $state
    else if ($state[$p:error]) then
      $state
    else
      let $state := p:shift(17, $input, $state)             (: QName^Token :)
      return $state
  return p:reduce($state, "FunctionName", $count)
};

(:~
 : Parse QName.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-QName($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state := p:lookahead1(160, $input, $state)           (: QName^Token | 'ancestor' | 'ancestor-or-self' | 'and' |
                                                               'ascending' | 'attribute' | 'case' | 'cast' |
                                                               'castable' | 'child' | 'collation' | 'comment' |
                                                               'declare' | 'default' | 'descendant' |
                                                               'descendant-or-self' | 'descending' | 'div' |
                                                               'document' | 'document-node' | 'element' | 'else' |
                                                               'empty' | 'empty-sequence' | 'eq' | 'every' | 'except' |
                                                               'following' | 'following-sibling' | 'for' | 'ge' | 'gt' |
                                                               'idiv' | 'if' | 'import' | 'instance' | 'intersect' |
                                                               'is' | 'item' | 'le' | 'let' | 'lt' | 'mod' | 'module' |
                                                               'ne' | 'node' | 'or' | 'order' | 'ordered' | 'parent' |
                                                               'preceding' | 'preceding-sibling' |
                                                               'processing-instruction' | 'property' | 'return' |
                                                               'satisfies' | 'schema-attribute' | 'schema-element' |
                                                               'self' | 'some' | 'stable' | 'text' | 'to' | 'treat' |
                                                               'typeswitch' | 'union' | 'unordered' | 'validate' |
                                                               'where' | 'xquery' :)
  let $state :=
    if ($state[$p:l1] = 71) then                            (: 'attribute' :)
      let $state := p:shift(71, $input, $state)             (: 'attribute' :)
      return $state
    else if ($state[$p:l1] = 81) then                       (: 'comment' :)
      let $state := p:shift(81, $input, $state)             (: 'comment' :)
      return $state
    else if ($state[$p:l1] = 91) then                       (: 'document-node' :)
      let $state := p:shift(91, $input, $state)             (: 'document-node' :)
      return $state
    else if ($state[$p:l1] = 92) then                       (: 'element' :)
      let $state := p:shift(92, $input, $state)             (: 'element' :)
      return $state
    else if ($state[$p:l1] = 95) then                       (: 'empty-sequence' :)
      let $state := p:shift(95, $input, $state)             (: 'empty-sequence' :)
      return $state
    else if ($state[$p:l1] = 109) then                      (: 'if' :)
      let $state := p:shift(109, $input, $state)            (: 'if' :)
      return $state
    else if ($state[$p:l1] = 116) then                      (: 'item' :)
      let $state := p:shift(116, $input, $state)            (: 'item' :)
      return $state
    else if ($state[$p:l1] = 128) then                      (: 'node' :)
      let $state := p:shift(128, $input, $state)            (: 'node' :)
      return $state
    else if ($state[$p:l1] = 140) then                      (: 'processing-instruction' :)
      let $state := p:shift(140, $input, $state)            (: 'processing-instruction' :)
      return $state
    else if ($state[$p:l1] = 145) then                      (: 'schema-attribute' :)
      let $state := p:shift(145, $input, $state)            (: 'schema-attribute' :)
      return $state
    else if ($state[$p:l1] = 146) then                      (: 'schema-element' :)
      let $state := p:shift(146, $input, $state)            (: 'schema-element' :)
      return $state
    else if ($state[$p:l1] = 152) then                      (: 'text' :)
      let $state := p:shift(152, $input, $state)            (: 'text' :)
      return $state
    else if ($state[$p:l1] = 156) then                      (: 'typeswitch' :)
      let $state := p:shift(156, $input, $state)            (: 'typeswitch' :)
      return $state
    else if ($state[$p:error]) then
      $state
    else
      let $state := p:parse-FunctionName($input, $state)
      return $state
  return p:reduce($state, "QName", $count)
};

(:~
 : Parse VarDecl.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-VarDecl($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state := p:shift(84, $input, $state)                 (: 'declare' :)
  let $state := p:lookahead1W(60, $input, $state)           (: S^WS | '(.' | 'variable' :)
  let $state := p:shift(160, $input, $state)                (: 'variable' :)
  let $state := p:lookahead1W(29, $input, $state)           (: S^WS | '$' | '(.' :)
  let $state := p:shift(28, $input, $state)                 (: '$' :)
  let $state := p:lookahead1W(164, $input, $state)          (: S^WS | QName^Token | '(.' | 'ancestor' |
                                                               'ancestor-or-self' | 'and' | 'ascending' | 'attribute' |
                                                               'case' | 'cast' | 'castable' | 'child' | 'collation' |
                                                               'comment' | 'declare' | 'default' | 'descendant' |
                                                               'descendant-or-self' | 'descending' | 'div' |
                                                               'document' | 'document-node' | 'element' | 'else' |
                                                               'empty' | 'empty-sequence' | 'eq' | 'every' | 'except' |
                                                               'following' | 'following-sibling' | 'for' | 'ge' | 'gt' |
                                                               'idiv' | 'if' | 'import' | 'instance' | 'intersect' |
                                                               'is' | 'item' | 'le' | 'let' | 'lt' | 'mod' | 'module' |
                                                               'ne' | 'node' | 'or' | 'order' | 'ordered' | 'parent' |
                                                               'preceding' | 'preceding-sibling' |
                                                               'processing-instruction' | 'property' | 'return' |
                                                               'satisfies' | 'schema-attribute' | 'schema-element' |
                                                               'self' | 'some' | 'stable' | 'text' | 'to' | 'treat' |
                                                               'typeswitch' | 'union' | 'unordered' | 'validate' |
                                                               'where' | 'xquery' :)
  let $state := p:parse-QName($input, $state)
  let $state := p:lookahead1W(106, $input, $state)          (: S^WS | '(.' | ':=' | 'as' | 'external' :)
  let $state :=
    if ($state[$p:error]) then
      $state
    else if ($state[$p:l1] = 68) then                       (: 'as' :)
      let $state := p:parse-TypeDeclaration($input, $state)
      return $state
    else
      $state
  let $state := p:lookahead1W(80, $input, $state)           (: S^WS | '(.' | ':=' | 'external' :)
  let $state :=
    if ($state[$p:l1] = 48) then                            (: ':=' :)
      let $state := p:shift(48, $input, $state)             (: ':=' :)
      let $state := p:lookahead1W(23, $input, $state)       (: EPSILON | S^WS | '(.' :)
      let $state := p:parse-ExprSingle($input, $state)
      return $state
    else if ($state[$p:error]) then
      $state
    else
      let $state := p:shift(100, $input, $state)            (: 'external' :)
      return $state
  return p:reduce($state, "VarDecl", $count)
};

(:~
 : Parse the 1st loop of production ModuleImport (zero or more). Use
 : tail recursion for iteratively updating the parser state.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-ModuleImport-1($input as xs:string, $state as item()+) as item()+
{
  if ($state[$p:error]) then
    $state
  else
    let $state := p:lookahead1W(76, $input, $state)         (: S^WS | '(.' | ',' | ';' :)
    return
      if ($state[$p:l1] != 38) then                         (: ',' :)
        $state
      else
        let $state := p:shift(38, $input, $state)           (: ',' :)
        let $state := p:lookahead1W(25, $input, $state)     (: StringLiteral | S^WS | '(.' :)
        let $state := p:parse-URILiteral($input, $state)
        return p:parse-ModuleImport-1($input, $state)
};

(:~
 : Parse ModuleImport.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-ModuleImport($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state := p:shift(110, $input, $state)                (: 'import' :)
  let $state := p:lookahead1W(51, $input, $state)           (: S^WS | '(.' | 'module' :)
  let $state := p:shift(123, $input, $state)                (: 'module' :)
  let $state := p:lookahead1W(66, $input, $state)           (: StringLiteral | S^WS | '(.' | 'namespace' :)
  let $state :=
    if ($state[$p:error]) then
      $state
    else if ($state[$p:l1] = 124) then                      (: 'namespace' :)
      let $state := p:shift(124, $input, $state)            (: 'namespace' :)
      let $state := p:lookahead1W(128, $input, $state)      (: S^WS | NCName^Token | '(.' | 'and' | 'ascending' |
                                                               'case' | 'cast' | 'castable' | 'collation' | 'default' |
                                                               'descending' | 'div' | 'else' | 'empty' | 'eq' |
                                                               'except' | 'for' | 'ge' | 'gt' | 'idiv' | 'instance' |
                                                               'intersect' | 'is' | 'le' | 'let' | 'lt' | 'mod' | 'ne' |
                                                               'or' | 'order' | 'return' | 'satisfies' | 'stable' |
                                                               'to' | 'treat' | 'union' | 'where' :)
      let $state := p:parse-NCName($input, $state)
      let $state := p:lookahead1W(36, $input, $state)       (: S^WS | '(.' | '=' :)
      let $state := p:shift(56, $input, $state)             (: '=' :)
      return $state
    else
      $state
  let $state := p:lookahead1W(25, $input, $state)           (: StringLiteral | S^WS | '(.' :)
  let $state := p:parse-URILiteral($input, $state)
  let $state := p:lookahead1W(81, $input, $state)           (: S^WS | '(.' | ';' | 'at' :)
  let $state :=
    if ($state[$p:error]) then
      $state
    else if ($state[$p:l1] = 70) then                       (: 'at' :)
      let $state := p:shift(70, $input, $state)             (: 'at' :)
      let $state := p:lookahead1W(25, $input, $state)       (: StringLiteral | S^WS | '(.' :)
      let $state := p:parse-URILiteral($input, $state)
      let $state := p:parse-ModuleImport-1($input, $state)
      return $state
    else
      $state
  return p:reduce($state, "ModuleImport", $count)
};

(:~
 : Parse SchemaPrefix.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-SchemaPrefix($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state :=
    if ($state[$p:l1] = 124) then                           (: 'namespace' :)
      let $state := p:shift(124, $input, $state)            (: 'namespace' :)
      let $state := p:lookahead1W(128, $input, $state)      (: S^WS | NCName^Token | '(.' | 'and' | 'ascending' |
                                                               'case' | 'cast' | 'castable' | 'collation' | 'default' |
                                                               'descending' | 'div' | 'else' | 'empty' | 'eq' |
                                                               'except' | 'for' | 'ge' | 'gt' | 'idiv' | 'instance' |
                                                               'intersect' | 'is' | 'le' | 'let' | 'lt' | 'mod' | 'ne' |
                                                               'or' | 'order' | 'return' | 'satisfies' | 'stable' |
                                                               'to' | 'treat' | 'union' | 'where' :)
      let $state := p:parse-NCName($input, $state)
      let $state := p:lookahead1W(36, $input, $state)       (: S^WS | '(.' | '=' :)
      let $state := p:shift(56, $input, $state)             (: '=' :)
      return $state
    else if ($state[$p:error]) then
      $state
    else
      let $state := p:shift(85, $input, $state)             (: 'default' :)
      let $state := p:lookahead1W(46, $input, $state)       (: S^WS | '(.' | 'element' :)
      let $state := p:shift(92, $input, $state)             (: 'element' :)
      let $state := p:lookahead1W(52, $input, $state)       (: S^WS | '(.' | 'namespace' :)
      let $state := p:shift(124, $input, $state)            (: 'namespace' :)
      return $state
  return p:reduce($state, "SchemaPrefix", $count)
};

(:~
 : Parse the 1st loop of production SchemaImport (zero or more). Use
 : tail recursion for iteratively updating the parser state.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-SchemaImport-1($input as xs:string, $state as item()+) as item()+
{
  if ($state[$p:error]) then
    $state
  else
    let $state := p:lookahead1W(76, $input, $state)         (: S^WS | '(.' | ',' | ';' :)
    return
      if ($state[$p:l1] != 38) then                         (: ',' :)
        $state
      else
        let $state := p:shift(38, $input, $state)           (: ',' :)
        let $state := p:lookahead1W(25, $input, $state)     (: StringLiteral | S^WS | '(.' :)
        let $state := p:parse-URILiteral($input, $state)
        return p:parse-SchemaImport-1($input, $state)
