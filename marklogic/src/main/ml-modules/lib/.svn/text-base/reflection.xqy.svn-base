     or $state[$p:lk] = 10778695                            (: 'attribute' 'let' '{' :)
     or $state[$p:lk] = 10778716                            (: 'element' 'let' '{' :)
     or $state[$p:lk] = 10778764                            (: 'processing-instruction' 'let' '{' :)
     or $state[$p:lk] = 10778951                            (: 'attribute' 'lt' '{' :)
     or $state[$p:lk] = 10778972                            (: 'element' 'lt' '{' :)
     or $state[$p:lk] = 10779020                            (: 'processing-instruction' 'lt' '{' :)
     or $state[$p:lk] = 10779207                            (: 'attribute' 'mod' '{' :)
     or $state[$p:lk] = 10779228                            (: 'element' 'mod' '{' :)
     or $state[$p:lk] = 10779276                            (: 'processing-instruction' 'mod' '{' :)
     or $state[$p:lk] = 10779975                            (: 'attribute' 'ne' '{' :)
     or $state[$p:lk] = 10779996                            (: 'element' 'ne' '{' :)
     or $state[$p:lk] = 10780044                            (: 'processing-instruction' 'ne' '{' :)
