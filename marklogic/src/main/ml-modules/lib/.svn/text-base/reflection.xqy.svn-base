  let $state := p:lookahead1W(146, $input, $state)          (: S^WS | EOF | '!=' | '(.' | ')' | '*' | '+' | ',' | '-' |
                                                               ';' | '<' | '<<' | '<=' | '=' | '>' | '>=' | '>>' | ']' |
