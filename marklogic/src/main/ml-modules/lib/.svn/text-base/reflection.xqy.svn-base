        else if ($state[$p:lk] = 24135) then                (: 'attribute' 'empty' :)
          let $state := p:lookahead3W(109, $input, $state)  (: S^WS | '(.' | 'greatest' | 'least' | '{' :)
          return $state
        else if ($state[$p:lk] = 28999) then                (: 'attribute' 'instance' :)
          let $state := p:lookahead3W(96, $input, $state)   (: S^WS | '(.' | 'of' | '{' :)
          return $state
        else if ($state[$p:lk] = 33863) then                (: 'attribute' 'order' :)
          let $state := p:lookahead3W(86, $input, $state)   (: S^WS | '(.' | 'by' | '{' :)
          return $state
        else if ($state[$p:lk] = 38215) then                (: 'attribute' 'stable' :)
          let $state := p:lookahead3W(97, $input, $state)   (: S^WS | '(.' | 'order' | '{' :)
          return $state
        else if ($state[$p:lk] = 17735                      (: 'attribute' 'descending' :)
              or $state[$p:lk] = 22599) then                (: 'attribute' 'descending' :)
          let $state := p:lookahead3W(116, $input, $state)  (: S^WS | '(.' | ',' | 'collation' | 'empty' | 'return' |
                                                               '{' :)
          return $state
        else if ($state[$p:lk] = 26439                      (: 'attribute' 'let' :)
              or $state[$p:lk] = 30791) then                (: 'attribute' 'let' :)
          let $state := p:lookahead3W(71, $input, $state)   (: S^WS | '$' | '(.' | '{' :)
          return $state
        else if ($state[$p:lk] = 19783                      (: 'attribute' 'castable' :)
