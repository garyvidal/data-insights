(:~
 : Parse SchemaImport.
 :
 : @param $input the input string.
 : @param $state the parser state.
 : @return the updated parser state.
 :)
declare function p:parse-SchemaImport($input as xs:string, $state as item()+) as item()+
{
  let $count := count($state)
  let $state := p:shift(110, $input, $state)                (: 'import' :)
  let $state := p:lookahead1W(58, $input, $state)           (: S^WS | '(.' | 'schema' :)
  let $state := p:shift(144, $input, $state)                (: 'schema' :)
  let $state := p:lookahead1W(100, $input, $state)          (: StringLiteral | S^WS | '(.' | 'default' | 'namespace' :)
  let $state :=
    if ($state[$p:error]) then
      $state
    else if ($state[$p:l1] != 6) then                       (: StringLiteral :)
      let $state := p:parse-SchemaPrefix($input, $state)
      return $state
    else
      $state
  let $state := p:lookahead1W(25, $input, $state)           (: StringLiteral | S^WS | '(.' :)
  let $state := p:parse-URILiteral($input, $state)
  let $state := p:lookahead1W(81, $input, $state)           (: S^WS | '(.' | ';' | 'at' :)
  let $state :=
    if ($state[$p:error]) then
