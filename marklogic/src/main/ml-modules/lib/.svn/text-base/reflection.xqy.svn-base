     or $state[$p:lk] = 10786140                            (: 'element' 'stable' '{' :)
     or $state[$p:lk] = 10786188                            (: 'processing-instruction' 'stable' '{' :)
     or $state[$p:lk] = 10787399                            (: 'attribute' 'to' '{' :)
     or $state[$p:lk] = 10787420                            (: 'element' 'to' '{' :)
     or $state[$p:lk] = 10787468                            (: 'processing-instruction' 'to' '{' :)
     or $state[$p:lk] = 10787655                            (: 'attribute' 'treat' '{' :)
     or $state[$p:lk] = 10787676                            (: 'element' 'treat' '{' :)
     or $state[$p:lk] = 10787724                            (: 'processing-instruction' 'treat' '{' :)
     or $state[$p:lk] = 10788167                            (: 'attribute' 'union' '{' :)
     or $state[$p:lk] = 10788188                            (: 'element' 'union' '{' :)
