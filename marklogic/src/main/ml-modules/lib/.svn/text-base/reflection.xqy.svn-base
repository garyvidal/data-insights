  let $state := p:lookahead1W(142, $input, $state)          (: S^WS | EOF | '!=' | '(.' | ')' | '*' | '+' | ',' | '-' |
                                                               ';' | '<' | '<<' | '<=' | '=' | '>' | '>=' | '>>' | ']' |
