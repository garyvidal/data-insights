{
  "role-name": "data-insight-role",
  "description": "Role for Data Insights MarkLogic Analyzer users. Grants all execute privileges required by the analysis pipeline: dynamic eval, module invocation, task spawning, in-place node updates, unrestricted URI writes, and REST API access.",

  "role": [
    "rest-reader",
    "rest-writer"
  ],

  "privilege": [
    {
      "privilege-name": "xdmp:eval",
      "action": "http://marklogic.com/xdmp/privileges/xdmp-eval",
      "kind": "execute"
    },
    {
      "privilege-name": "xdmp:eval-in",
      "action": "http://marklogic.com/xdmp/privileges/xdmp-eval-in",
      "kind": "execute"
    },
    {
      "privilege-name": "xdmp:invoke",
      "action": "http://marklogic.com/xdmp/privileges/xdmp-invoke",
      "kind": "execute"
    },
    {
      "privilege-name": "xdmp:invoke-in",
      "action": "http://marklogic.com/xdmp/privileges/xdmp-invoke-in",
      "kind": "execute"
    },
    {
      "privilege-name": "xdmp:spawn",
      "action": "http://marklogic.com/xdmp/privileges/xdmp-spawn",
      "kind": "execute"
    },
    {
      "privilege-name": "xdmp:spawn-function",
      "action": "http://marklogic.com/xdmp/privileges/xdmp-spawn-function",
      "kind": "execute"
    },
    {
      "privilege-name": "xdmp:node-update",
      "action": "http://marklogic.com/xdmp/privileges/xdmp-node-update",
      "kind": "execute"
    },
    {
      "privilege-name": "any-uri",
      "action": "http://marklogic.com/xdmp/privileges/any-uri",
      "kind": "execute"
    },
    {
      "privilege-name": "unprotected-collections",
      "action": "http://marklogic.com/xdmp/privileges/unprotected-collections",
      "kind": "execute"
    },
    {
      "privilege-name": "xdmp:add-response-header",
      "action": "http://marklogic.com/xdmp/privileges/xdmp-add-response-header",
      "kind": "execute"
    },
    {
      "privilege-name": "xdmp:value",
      "action": "http://marklogic.com/xdmp/privileges/xdmp-value",
      "kind": "execute"
    },
    {
      "privilege-name": "xdmp:with-namespaces",
      "action": "http://marklogic.com/xdmp/privileges/xdmp-with-namespaces",
      "kind": "execute"
    },
    {
      "privilege-name": "xdmp:spawn-in",
      "action": "http://marklogic.com/xdmp/privileges/xdmp-spawn-in",
      "kind": "execute"
    }
  ]
}
